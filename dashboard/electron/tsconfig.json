{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "../dist-electron",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": ".."
  },
  "include": [
    "../electron/**/*.ts",
    "../src/lib/db.ts",
    "../src/lib/queries.ts",
    "../src/lib/config-tracker.ts",
    "../src/lib/registered-tools.ts",
    "../src/lib/pricing-sync.ts"
  ]
}
